MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@studentfinancetracker.com

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=true
